# ── Database ──────────────────────────────────────────────────────
DATABASE_URL="postgresql://apiuser:apipassword@localhost:5432/userdb?schema=public"

# ── Postgres (usado pelo docker-compose) ─────────────────────────
POSTGRES_USER=apiuser
POSTGRES_PASSWORD=apipassword
POSTGRES_DB=userdb

# ── App ───────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── JWT ────────────────────────────────────────────────────────────
JWT_SECRET="seu-segredo-super-secreto-aqui-mude-em-producao"

# ── Recuperação de senha ──────────────────────────────────────────
FRONTEND_RESET_PASSWORD_URL="http://localhost:5173/redefinir-senha"
MAIL_FROM="\"Equipe Manual do Proprietário\" <no-reply@manualproprietario.local>"

# SMTP do Gmail
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=465
SMTP_USER="seuemail@gmail.com"
# Use uma Senha de App do Google, não a senha comum da conta.
SMTP_PASS="sua_senha_de_app_do_google"
