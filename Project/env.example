# ── Database ──────────────────────────────────────────────────────
DATABASE_URL="postgresql://apiuser:apipassword@localhost:5432/userdb?schema=public"

# ── Postgres (usado pelo docker-compose) ─────────────────────────
POSTGRES_USER=apiuser
POSTGRES_PASSWORD=apipassword
POSTGRES_DB=userdb

# ── App ───────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── JWT ────────────────────────────────────────────────────────────
JWT_SECRET="seu-segredo-super-secreto-aqui-mude-em-producao"
